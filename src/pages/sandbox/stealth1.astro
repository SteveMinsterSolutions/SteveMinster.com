<script is:inline>
// ── PASSWORD GATE LOGIC ────────────────────────────────────────
(function() {
  const PASS = 'D3@lers';
  const SESSION_KEY = 'bluefields_stealth_auth';

  function unlock() {
    document.getElementById('gate').classList.add('hidden');
    document.getElementById('content').classList.add('visible');
    try { sessionStorage.setItem(SESSION_KEY, '1'); } catch(e) {}
    setTimeout(() => {
      document.getElementById('gate').style.display = 'none';
    }, 450);
  }

  // Check if already authenticated this session
  try {
    if (sessionStorage.getItem(SESSION_KEY) === '1') {
      unlock();
    }
  } catch(e) {}

  function attempt() {
    const val = document.getElementById('gate-input').value;
    if (val === PASS) {
      unlock();
    } else {
      const errEl = document.getElementById('gate-error');
      errEl.textContent = 'Incorrect code. Try again.';
      document.getElementById('gate-input').value = '';
      document.getElementById('gate-input').focus();
      setTimeout(() => { errEl.textContent = ''; }, 3000);
    }
  }

  document.getElementById('gate-btn').addEventListener('click', attempt);
  document.getElementById('gate-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') attempt();
  });
})();
</script>

