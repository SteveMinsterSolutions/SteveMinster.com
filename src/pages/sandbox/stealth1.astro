<!-- ── SCRIPTS ────────────────────────────────────────────────── -->
<script is:inline>
// ──────────────────────────────────────────────────────────────
// CONFIG — replace FORMSPREE_ID with your actual Formspree form ID
// ──────────────────────────────────────────────────────────────
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mpqjvkar';
const STORAGE_KEY = 'bluefields_sdp_draft';

// ──────────────────────────────────────────────────────────────
// COLLAPSIBLE SECTIONS
// ──────────────────────────────────────────────────────────────
document.querySelectorAll('.section-header').forEach(header => {
  header.addEventListener('click', () => {
    const card = header.closest('.section-card');
    const isOpen = card.classList.contains('open');
    card.classList.toggle('open', !isOpen);
    header.setAttribute('aria-expanded', String(!isOpen));
  });
  header.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); header.click(); }
  });
});

// ──────────────────────────────────────────────────────────────
// RADIO GROUPS
// ──────────────────────────────────────────────────────────────
document.querySelectorAll('.radio-opt').forEach(opt => {
  opt.addEventListener('click', () => {
    const name = opt.querySelector('input').name;
    document.querySelectorAll(`input[name="${name}"]`).forEach(r => {
      r.closest('.radio-opt').classList.remove('selected');
    });
    opt.classList.add('selected');
    opt.querySelector('input').checked = true;
    autoSave();
  });
});

// ──────────────────────────────────────────────────────────────
// DRAG-AND-DROP RANKING
// ──────────────────────────────────────────────────────────────
function initRankList(listId, hiddenId) {
  const list = document.getElementById(listId);
  if (!list) return;
  let dragSrc = null;

  list.querySelectorAll('.rank-item').forEach(item => {
    item.addEventListener('dragstart', e => {
      dragSrc = item;
      item.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    item.addEventListener('dragend', () => {
      item.classList.remove('dragging');
      list.querySelectorAll('.rank-item').forEach(i => i.classList.remove('drag-over'));
      updateRankBadges(list, hiddenId);
      autoSave();
    });
    item.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      if (item !== dragSrc) {
        list.querySelectorAll('.rank-item').forEach(i => i.classList.remove('drag-over'));
        item.classList.add('drag-over');
      }
    });
    item.addEventListener('drop', e => {
      e.preventDefault();
      if (dragSrc && item !== dragSrc) {
        const items = [...list.querySelectorAll('.rank-item')];
        const srcIdx = items.indexOf(dragSrc);
        const tgtIdx = items.indexOf(item);
        if (srcIdx < tgtIdx) list.insertBefore(dragSrc, item.nextSibling);
        else list.insertBefore(dragSrc, item);
      }
    });
  });
  updateRankBadges(list, hiddenId);
}

function updateRankBadges(list, hiddenId) {
  const items = list.querySelectorAll('.rank-item');
  const order = [];
  items.forEach((item, idx) => {
    item.querySelector('.rank-badge').textContent = idx + 1;
    order.push(item.dataset.val);
  });
  if (hiddenId) document.getElementById(hiddenId).value = order.join(',');
}

initRankList('rank-3-1', 'q3_1');
initRankList('rank-7-1', 'q7_1');

// ──────────────────────────────────────────────────────────────
// CHARACTER COUNTS
// ──────────────────────────────────────────────────────────────
document.querySelectorAll('textarea').forEach(ta => {
  const ccEl = document.getElementById('cc-' + ta.id);
  if (ccEl) {
    ta.addEventListener('input', () => { ccEl.textContent = ta.value.length + ' characters'; });
  }
});

// ──────────────────────────────────────────────────────────────
// AUTO-SAVE TO localStorage
// ──────────────────────────────────────────────────────────────
let saveTimer;
function autoSave() {
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    const data = collectFormData();
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      showAutosave();
    } catch(e) {}
    updateProgress();
  }, 800);
}

function showAutosave() {
  const banner = document.getElementById('autosave-banner');
  banner.classList.add('visible');
  setTimeout(() => banner.classList.remove('visible'), 2500);
}

document.querySelectorAll('textarea, input[type="text"], input[type="number"]').forEach(el => {
  el.addEventListener('input', autoSave);
});

// ──────────────────────────────────────────────────────────────
// COLLECT FORM DATA
// ──────────────────────────────────────────────────────────────
function collectFormData() {
  const data = {};
  const form = document.getElementById('sdp-form');
  const els = form.querySelectorAll('textarea, input[type="text"], input[type="number"], input[type="hidden"]');
  els.forEach(el => { if (el.name) data[el.name] = el.value; });
  // Radios
  form.querySelectorAll('input[type="radio"]:checked').forEach(r => { data[r.name] = r.value; });
  return data;
}

// ──────────────────────────────────────────────────────────────
// RESTORE FROM localStorage
// ──────────────────────────────────────────────────────────────
function restoreDraft() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    const data = JSON.parse(raw);
    Object.keys(data).forEach(key => {
      const el = document.querySelector(`[name="${key}"]`);
      if (!el) return;
      if (el.type === 'hidden') {
        el.value = data[key];
        // Restore rank order
        if (key === 'q3_1') restoreRankOrder('rank-3-1', data[key], 'q3_1');
        if (key === 'q7_1') restoreRankOrder('rank-7-1', data[key], 'q7_1');
      } else if (el.tagName === 'TEXTAREA' || el.type === 'text' || el.type === 'number') {
        el.value = data[key];
        const cc = document.getElementById('cc-' + key);
        if (cc) cc.textContent = el.value.length + ' characters';
      }
    });
    // Restore radios
    Object.keys(data).forEach(key => {
      const radio = document.querySelector(`input[type="radio"][name="${key}"][value="${data[key]}"]`);
      if (radio) {
        radio.checked = true;
        radio.closest('.radio-opt').classList.add('selected');
      }
    });
    updateProgress();
  } catch(e) {}
}

function restoreRankOrder(listId, orderStr, hiddenId) {
  if (!orderStr) return;
  const order = orderStr.split(',');
  const list = document.getElementById(listId);
  if (!list) return;
  order.forEach(val => {
    const item = list.querySelector(`[data-val="${val}"]`);
    if (item) list.appendChild(item);
  });
  updateRankBadges(list, hiddenId);
}

// ──────────────────────────────────────────────────────────────
// PROGRESS CALCULATION
// ──────────────────────────────────────────────────────────────
const sectionFields = {
  s1: ['q1_1','q1_2','q1_3','q1_4','q1_5','q1_6','q1_7','q1_8','q1_9','q1_10'],
  s2: ['q2_1','q2_2','q2_3','q2_4','q2_5','q2_6','q2_7','q2_8','q2_9','q2_10'],
  s3: ['q3_1','q3_2','q3_3','q3_4','q3_5','q3_6','q3_7','q3_8'],
  s4: ['q4_1','q4_2','q4_3','q4_4a','q4_4b','q4_5','q4_6','q4_7'],
  s5: ['q5_1','q5_2','q5_3','q5_4','q5_5'],
  s6: ['q6_1','q6_2','q6_3','q6_4','q6_5'],
  s7: ['q7_1','q7_2','q7_3','q7_4','q7_5'],
};

function getFieldValue(name) {
  const el = document.querySelector(`[name="${name}"]`);
  if (!el) return '';
  if (el.type === 'radio') {
    const checked = document.querySelector(`input[name="${name}"]:checked`);
    return checked ? checked.value : '';
  }
  return el.value || '';
}

function updateProgress() {
  let total = 0, filled = 0;
  Object.keys(sectionFields).forEach(sid => {
    const fields = sectionFields[sid];
    let secFilled = 0;
    fields.forEach(f => {
      total++;
      const val = getFieldValue(f);
      if (val && val.trim().length > 0) { filled++; secFilled++; }
    });
    const pct = secFilled / fields.length;
    const statusEl = document.getElementById(sid + '-status');
    const card = document.getElementById(sid);
    const navDot = document.querySelector(`[data-section="${sid}"] .nav-dot`);
    const navPill = document.querySelector(`[data-section="${sid}"]`);
    if (pct === 0) {
      statusEl.textContent = 'Not started';
      card.classList.remove('complete');
      if (navDot) navDot.style.background = '';
      if (navPill) navPill.classList.remove('complete');
    } else if (pct === 1) {
      statusEl.textContent = 'Complete ✓';
      card.classList.add('complete');
      if (navDot) navDot.style.background = 'var(--success)';
      if (navPill) navPill.classList.add('complete');
    } else {
      statusEl.textContent = Math.round(pct * 100) + '% complete';
      card.classList.remove('complete');
      if (navPill) navPill.classList.remove('complete');
    }
  });
  const pct = total > 0 ? Math.round((filled / total) * 100) : 0;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('pct-label').textContent = pct + '%';
}

// ──────────────────────────────────────────────────────────────
// SUBMIT
// ──────────────────────────────────────────────────────────────
document.getElementById('sdp-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const errEl = document.getElementById('submit-error');
  errEl.style.display = 'none';

  const data = collectFormData();

  // Build readable email body
  const body = buildEmailBody(data);
  const submitData = { ...data, _subject: 'SDP Discovery Questionnaire — Aaron Krupka', body };

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.textContent = 'Submitting…';

  try {
    const resp = await fetch(FORMSPREE_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(submitData)
    });
    if (resp.ok) {
      document.getElementById('success-overlay').style.display = 'block';
      document.querySelector('.form-footer').style.display = 'none';
      localStorage.removeItem(STORAGE_KEY);
      window.scrollTo({ top: document.getElementById('success-overlay').offsetTop - 100, behavior: 'smooth' });
    } else {
      const json = await resp.json();
      errEl.textContent = 'Submission failed: ' + (json.error || 'Unknown error. Please try again or email Steve directly.');
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg> Submit Answers';
    }
  } catch(err) {
    errEl.textContent = 'Network error. Your draft has been saved locally. Please try again or contact Steve directly at steve@minstersolutions.com.';
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg> Submit Answers';
  }
});

