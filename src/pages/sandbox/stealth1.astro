  const labels = {
    q1_1: '1.1 Hard declination criteria', q1_2: '1.2 Referral triggers', q1_3: '1.3 Risk quality segmentation', q1_4: '1.4 Max account size', q1_5: '1.5 Multi-location rules', q1_6: '1.6 Demo ride requirements', q1_7: '1.7 Manufacturer brand exclusions/approvals', q1_8: '1.8 Service/repair appetite', q1_9_radio: '1.9 Marine/watercraft handling (choice)', q1_9: '1.9 Marine/watercraft (detail)', q1_10: '1.10 Financial requirements',
    q2_1: '2.1 Package structure', q2_2_radio: '2.2 Lower limits allowed (choice)', q2_2: '2.2 Lower limits (detail)', q2_3: '2.3 Inventory valuation approach', q2_4: '2.4 Garage keepers structure', q2_5: '2.5 Professional/mgmt liability placement', q2_6: '2.6 Inland marine scope', q2_7: '2.7 Endorsements needed at launch', q2_8: '2.8 Competitor table-stakes vs. differentiators', q2_9: '2.9 Business income guardrails', q2_10: '2.10 Excess/umbrella structure',
    q3_1: '3.1 Rating variable ranking', q3_2: '3.2 Experience mod approach', q3_3: '3.3 Loss prevention credits', q3_4_radio: '3.4 New business penalty (choice)', q3_4: '3.4 New business penalty (detail)', q3_5: '3.5 Bundling discount philosophy', q3_6: '3.6 Territory granularity', q3_7: '3.7 Min earned premium/short-rate', q3_8_radio: '3.8 Mid-term inventory changes (choice)', q3_8: '3.8 Mid-term inventory (detail)',
    q4_1: '4.1 Submission vs. bind data requirements', q4_2: '4.2 Good submission documents', q4_3: '4.3 Quick-quote / indicative pricing', q4_4a: '4.4 Submission to quote turnaround', q4_4b: '4.4 Submission to bind turnaround', q4_5: '4.5 Agent pain points', q4_6: '4.6 Early adopter producers', q4_7_radio: '4.7 Renewal workflow (choice)', q4_7: '4.7 Renewal workflow (detail)',
    q5_1: '5.1 Top loss types (frequency/severity)', q5_2: '5.2 Loss control mandatory vs. recommended', q5_3: '5.3 Pre-bind inspection requirements', q5_4: '5.4 Emerging risks', q5_5: '5.5 Claims reporting requirements',
    q6_1: '6.1 Competitor analysis', q6_2: '6.2 Market rate range', q6_3: '6.3 Coverage gaps in competing programs', q6_4: '6.4 Business stickiness / retention', q6_5: '6.5 NPDA relationship',
    q7_1: '7.1 Deliverable build order (rank)', q7_2: '7.2 Time availability', q7_3: '7.3 External dependencies', q7_4: '7.4 Reference documents available', q7_5_radio: '7.5 Working style preference (choice)', q7_5: '7.5 Working style (detail)'
  };
  let out = 'BLUEFIELDS SDP — AARON KRUPKA DISCOVERY QUESTIONNAIRE\nSubmitted: ' + new Date().toLocaleString() + '\n\n';
  out += '='.repeat(60) + '\n\n';
  Object.keys(labels).forEach(key => {
    const val = data[key] || '(not answered)';
    out += labels[key] + '\n' + val + '\n\n';
  });
  return out;
}

// ──────────────────────────────────────────────────────────────
// SAVE DRAFT BUTTON
// ──────────────────────────────────────────────────────────────
document.getElementById('save-draft-btn').addEventListener('click', () => {
  const data = collectFormData();
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    showAutosave();
  } catch(e) {
    alert('Could not save draft to local storage. Please try a different browser.');
  }
});

// ──────────────────────────────────────────────────────────────
// EXPORT PDF
// ──────────────────────────────────────────────────────────────
document.getElementById('export-pdf-btn').addEventListener('click', () => {
  document.querySelectorAll('.section-card').forEach(c => c.classList.add('open'));
  setTimeout(() => window.print(), 200);
});

// ──────────────────────────────────────────────────────────────
// CLEAR FORM
// ──────────────────────────────────────────────────────────────
document.getElementById('clear-btn').addEventListener('click', () => {
  if (!confirm('Clear all answers? This cannot be undone.')) return;
  document.querySelectorAll('textarea, input[type="text"], input[type="number"]').forEach(el => { el.value = ''; });
  document.querySelectorAll('input[type="radio"]').forEach(r => { r.checked = false; r.closest('.radio-opt').classList.remove('selected'); });
  document.querySelectorAll('.char-count').forEach(cc => { cc.textContent = '0 characters'; });
  try { localStorage.removeItem(STORAGE_KEY); } catch(e) {}
  updateProgress();
});

// ──────────────────────────────────────────────────────────────
// INIT
// ──────────────────────────────────────────────────────────────
restoreDraft();
updateProgress();
</script>

</div>

