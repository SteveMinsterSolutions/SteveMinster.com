---
// Bluefields Stealth Project — SDP Discovery Questionnaire
// Password protected: D3@lers
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bluefields Stealth Project — SteveMinster.com</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" />

  <style is:inline>
    /* ── GATE STYLES ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #1B2A4A;
      --electric: #2D7DD2;
      --lime: #97D700;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--navy);
      margin: 0;
      padding: 0;
    }

    #gate {
      position: fixed;
      inset: 0;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.4s ease;
    }

    #gate.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .gate-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      text-align: center;
      padding: 24px;
    }

    .gate-logo {
      margin-bottom: 28px;
    }

    .gate-title {
      font-size: 22px;
      font-weight: 600;
      color: white;
      margin-bottom: 20px;
      letter-spacing: 0.01em;
    }

    .gate-subtitle {
      font-size: 13px;
      color: rgba(255,255,255,0.5);
      margin-bottom: 24px;
      letter-spacing: 0.04em;
    }

    .gate-input {
      width: 200px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 10px;
      padding: 16px 20px;
      font-family: 'Space Grotesk', monospace;
      font-size: 14px;
      letter-spacing: 0.18em;
      color: white;
      text-align: center;
      outline: none;
      caret-color: var(--lime);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      margin-bottom: 16px;
    }

    .gate-input::placeholder {
      color: rgba(255,255,255,0.25);
      letter-spacing: 0.22em;
    }

    .gate-input:focus {
      border-color: rgba(255,255,255,0.35);
      box-shadow: 0 0 0 3px rgba(151,215,0,0.12);
    }

    .gate-error {
      font-size: 12px;
      color: #ff6b6b;
      margin-bottom: 12px;
      min-height: 18px;
      letter-spacing: 0.04em;
    }

    .gate-btn {
      background: var(--lime);
      color: #111;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 15px;
      font-weight: 600;
      padding: 14px 48px;
      border: none;
      border-radius: 100px;
      cursor: pointer;
      letter-spacing: 0.03em;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .gate-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(151,215,0,0.3);
    }

    .gate-btn:active {
      transform: translateY(0);
    }

    /* ── QUESTIONNAIRE CONTENT ───────────────────────────────── */
    #content {
      display: none;
    }

    #content.visible {
      display: block;
    }

    :root {
    --navy: #0C1B33;
    --navy-mid: #152744;
    --navy-light: #1E3A5F;
    --accent: #2E7BFF;
    --accent-bright: #4D9FFF;
    --gold: #C9A84C;
    --white: #FFFFFF;
    --off-white: #F5F7FA;
    --light-border: #D6DDE8;
    --text-dark: #0C1B33;
    --text-mid: #4A5568;
    --text-light: #718096;
    --success: #2F9E6A;
    --warning: #E6900A;
    --danger: #C53030;
    --section-radius: 12px;
    --input-radius: 6px;
    --transition: 0.22s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--off-white);
    color: var(--text-dark);
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── HEADER ──────────────────────────────────────── */
  .site-header {
    background: var(--navy);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.35);
  }

  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo-area {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-mark {
    width: 38px;
    height: 38px;
    background: var(--accent);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    color: white;
    letter-spacing: -1px;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-brand {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .logo-sub {
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 300;
  }

  .progress-wrap {
    flex: 1;
    max-width: 320px;
  }

  .progress-label {
    font-size: 11px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 5px;
    display: flex;
    justify-content: space-between;
  }

  .progress-bar-bg {
    background: rgba(255,255,255,0.12);
    border-radius: 100px;
    height: 5px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright));
    border-radius: 100px;
    transition: width 0.4s ease;
    width: 0%;
  }

  /* ── HERO ────────────────────────────────────────── */
  .hero {
    background: linear-gradient(145deg, var(--navy) 0%, var(--navy-light) 100%);
    padding: 56px 24px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-bright);
    font-weight: 500;
    margin-bottom: 14px;
  }

  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(28px, 5vw, 42px);
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 16px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero h1 em {
    font-style: italic;
    color: rgba(255,255,255,0.65);
  }

  .hero-desc {
    color: rgba(255,255,255,0.65);
    font-size: 15px;
    max-width: 560px;
    margin: 0 auto 28px;
    font-weight: 300;
    line-height: 1.7;
  }

  .hero-meta {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .meta-chip {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    padding: 5px 14px;
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.04em;
  }

  /* ── SECTION NAV ─────────────────────────────────── */
  .section-nav {
    background: var(--white);
    border-bottom: 1px solid var(--light-border);
    position: sticky;
    top: 73px;
    z-index: 90;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .section-nav-inner {
    display: flex;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    gap: 0;
  }

  .nav-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-light);
    letter-spacing: 0.04em;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: var(--transition);
    text-decoration: none;
  }

  .nav-pill:hover { color: var(--accent); }
  .nav-pill.complete { color: var(--success); }
  .nav-pill.complete .nav-dot { background: var(--success); }

  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--light-border);
    transition: var(--transition);
    flex-shrink: 0;
  }

  /* ── MAIN CONTENT ────────────────────────────────── */
  .main {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 24px 80px;
  }

  /* ── SECTION CARDS ───────────────────────────────── */
  .section-card {
    background: var(--white);
    border: 1px solid var(--light-border);
    border-radius: var(--section-radius);
    margin-bottom: 16px;
    overflow: hidden;
    transition: box-shadow var(--transition);
  }

  .section-card:hover { box-shadow: 0 4px 24px rgba(12,27,51,0.07); }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    cursor: pointer;
    user-select: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), background var(--transition);
  }

  .section-card.open .section-header {
    border-bottom-color: var(--light-border);
    background: var(--off-white);
  }

  .section-num {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--navy);
    color: white;
    font-family: 'DM Serif Display', serif;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background var(--transition);
  }

  .section-card.complete .section-num { background: var(--success); }

  .section-title-wrap { flex: 1; }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 17px;
    color: var(--navy);
    line-height: 1.2;
  }

  .section-subtitle {
    font-size: 12px;
    color: var(--text-light);
    margin-top: 2px;
  }

  .section-status {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 100px;
    background: var(--off-white);
    color: var(--text-light);
    border: 1px solid var(--light-border);
    flex-shrink: 0;
  }

  .section-card.complete .section-status {
    background: #EDF7F2;
    color: var(--success);
    border-color: #B2DFC7;
  }

  .section-chevron {
    color: var(--text-light);
    transition: transform var(--transition);
    flex-shrink: 0;
  }

  .section-card.open .section-chevron { transform: rotate(180deg); }

  .section-body {
    display: none;
    padding: 28px 24px 24px;
  }

  .section-card.open .section-body { display: block; }

  .section-helper {
    background: linear-gradient(135deg, #EEF4FF, #F5F7FA);
    border: 1px solid #D0E0FF;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 13px;
    color: var(--navy-light);
    margin-bottom: 28px;
    line-height: 1.5;
  }

  /* ── QUESTIONS ───────────────────────────────────── */
  .question {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--light-border);
  }

  .question:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .q-label {
    display: block;
    font-weight: 500;
    font-size: 14px;
    color: var(--navy);
    margin-bottom: 6px;
    line-height: 1.4;
  }

  .q-num {
    font-family: 'DM Serif Display', serif;
    color: var(--accent);
    margin-right: 6px;
    font-size: 15px;
  }

  .q-helper {
    font-size: 12px;
    color: var(--text-light);
    margin-bottom: 10px;
    font-style: italic;
    line-height: 1.5;
  }

  /* ── INPUTS ──────────────────────────────────────── */
  textarea, input[type="text"], input[type="number"], input[type="email"] {
    width: 100%;
    border: 1.5px solid var(--light-border);
    border-radius: var(--input-radius);
    padding: 10px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text-dark);
    background: var(--white);
    transition: border-color var(--transition), box-shadow var(--transition);
    outline: none;
    resize: vertical;
  }

  textarea:focus, input[type="text"]:focus, input[type="number"]:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(46,123,255,0.1);
  }

  textarea { min-height: 100px; }

  .input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .input-row .field-label {
    font-size: 12px;
    color: var(--text-mid);
    margin-bottom: 5px;
    font-weight: 500;
  }

  /* ── RADIO / CHECKBOX ────────────────────────────── */
  .radio-group, .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }

  .radio-opt, .check-opt {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    border: 1.5px solid var(--light-border);
    border-radius: 100px;
    cursor: pointer;
    font-size: 13px;
    color: var(--text-mid);
    transition: var(--transition);
    user-select: none;
    font-weight: 500;
  }

  .radio-opt:hover, .check-opt:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(46,123,255,0.04);
  }

  .radio-opt input, .check-opt input { display: none; }

  .radio-opt.selected, .check-opt.checked {
    border-color: var(--accent);
    background: rgba(46,123,255,0.07);
    color: var(--accent);
  }

  .radio-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid currentColor;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .radio-opt.selected .radio-dot {
    background: var(--accent);
    border-color: var(--accent);
  }

  /* ── DRAG RANK ───────────────────────────────────── */
  .rank-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rank-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--off-white);
    border: 1.5px solid var(--light-border);
    border-radius: var(--input-radius);
    cursor: grab;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-mid);
    transition: var(--transition);
    user-select: none;
  }

  .rank-item:active { cursor: grabbing; opacity: 0.7; }
  .rank-item.dragging { opacity: 0.4; background: #EEF4FF; border-color: var(--accent); }
  .rank-item.drag-over { border-color: var(--accent); background: rgba(46,123,255,0.06); }

  .rank-badge {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--navy);
    color: white;
    font-size: 11px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .drag-handle {
    color: var(--light-border);
    flex-shrink: 0;
    font-size: 16px;
    letter-spacing: -2px;
  }

  /* ── AUTOSAVE BANNER ─────────────────────────────── */
  .autosave-banner {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: var(--navy);
    color: white;
    font-size: 12px;
    padding: 8px 14px;
    border-radius: 100px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 200;
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .autosave-banner.visible { opacity: 1; }

  /* ── FORM FOOTER ─────────────────────────────────── */
  .form-footer {
    background: var(--white);
    border: 1px solid var(--light-border);
    border-radius: var(--section-radius);
    padding: 28px 24px;
    margin-top: 24px;
  }

  .footer-title {
    font-family: 'DM Serif Display', serif;
    font-size: 18px;
    color: var(--navy);
    margin-bottom: 6px;
  }

  .footer-desc {
    font-size: 13px;
    color: var(--text-light);
    margin-bottom: 20px;
  }

  .btn-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 11px 22px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: var(--transition);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover { background: #1A6AEE; box-shadow: 0 4px 16px rgba(46,123,255,0.35); }

  .btn-secondary {
    background: var(--off-white);
    color: var(--navy);
    border: 1.5px solid var(--light-border);
  }

  .btn-secondary:hover { background: #EAF0FA; border-color: var(--accent); color: var(--accent); }

  .btn-outline {
    background: transparent;
    color: var(--text-mid);
    border: 1.5px solid var(--light-border);
  }

  .btn-outline:hover { border-color: var(--navy); color: var(--navy); }

  /* ── SUCCESS STATE ───────────────────────────────── */
  .success-overlay {
    display: none;
    background: var(--white);
    border: 1px solid var(--light-border);
    border-radius: var(--section-radius);
    padding: 56px 24px;
    text-align: center;
    margin-top: 24px;
  }

  .success-icon {
    width: 64px;
    height: 64px;
    background: #EDF7F2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 28px;
  }

  .success-title {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .success-desc {
    font-size: 14px;
    color: var(--text-light);
    max-width: 420px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── PRINT STYLES ────────────────────────────────── */
  @media print {
    .site-header, .section-nav, .autosave-banner, .btn-group { display: none !important; }
    .section-body { display: block !important; }
    .section-card { box-shadow: none !important; border: 1px solid #ccc !important; break-inside: avoid; }
    body { background: white; }
    .hero { background: white; color: black; }
    .hero h1, .hero-desc, .hero-eyebrow { color: black !important; }
  }

  /* ── RESPONSIVE ──────────────────────────────────── */
  @media (max-width: 640px) {
    .header-inner { flex-wrap: wrap; }
    .progress-wrap { order: 3; width: 100%; max-width: 100%; }
    .hero { padding: 40px 20px 36px; }
    .section-header { padding: 16px 18px; gap: 12px; }
    .section-body { padding: 20px 18px; }
    .input-row { grid-template-columns: 1fr; }
    .hero-meta { flex-direction: column; align-items: center; }
    .section-nav-inner { padding: 0 12px; }
    .nav-pill { padding: 10px 12px; font-size: 11px; }
  }

  .char-count { font-size: 11px; color: var(--text-light); text-align: right; margin-top: 4px; }

  .divider { height: 1px; background: var(--light-border); margin: 32px 0; }

  .required-star { color: var(--accent); margin-left: 2px; }

  </style>
</head>

<body>

<!-- ── PASSWORD GATE ──────────────────────────────────────────── -->
<div id="gate">
  <div class="gate-inner">
    <div class="gate-logo">
      <!-- SM Logo Mark -->
      <svg xmlns="http://www.w3.org/2000/svg" width="56" height="64" viewBox="0 0 56 64" fill="none">
        <!-- Navy container box -->
        <rect x="0" y="8" width="48" height="48" rx="10" fill="#1B2A4A" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
        <!-- S lightning bolt — inside box (white) -->
